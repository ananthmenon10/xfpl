    "games-json": {
      "description": "Manage games json",
      "base_url": "https://livefpl.us",
      "endpoints": {
        "get-live-games": {
          "method": "GET",
          "path": "/api/games.json",
          "description": "Array of arrays — one per Premier League fixture in the active gameweek.\nEach entry: [home, away, hscore, ascore, status, source, h_scorers,\nh_assists, a_scorers, a_assists, bps_top, ..., per-player live entries\nwith BPS, minutes, clean sheets, bonus]. Update frequency: ~1-2 min\nduring live matches.",
          "params": [
            {
              "name": "_",
              "type": "string",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Cache-busting epoch timestamp",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
