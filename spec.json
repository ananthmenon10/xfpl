          "endpoints": {
            "get-entry-picks": {
              "method": "GET",
              "path": "/entry/{managerId}/event/{eventId}/picks/",
              "description": "Manager picks for a specific gameweek",
              "params": [
                {
                  "name": "managerId",
                  "type": "int",
                  "required": true,
                  "positional": true,
                  "path_param": true,
                  "default": null,
                  "description": "Manager id",
                  "fields": null
                },
                {
                  "name": "eventId",
                  "type": "int",
                  "required": true,
                  "positional": true,
                  "path_param": true,
                  "default": null,
                  "description": "Event id",
                  "fields": null
                }
              ],
              "body": [],
              "response": {
                "type": "",
                "item": ""
              },
              "pagination": null,
              "no_auth": true
            }
          }
        },
        "history": {
          "description": "Manage history",
          "endpoints": {
            "get-entry": {
              "method": "GET",
              "path": "/entry/{managerId}/history/",
              "description": "Manager history (per-GW score, past seasons, chips)",
              "params": [
                {
                  "name": "managerId",
                  "type": "int",
                  "required": true,
                  "positional": true,
                  "path_param": true,
                  "default": null,
                  "description": "Manager id",
                  "fields": null
