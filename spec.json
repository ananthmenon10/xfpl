{
  "name": "xfpl",
  "description": "Combined CLI for multiple API services",
  "version": "1.0.0",
  "base_url": "https://fantasy.premierleague.com/api",
  "owner": "ananth-menon",
  "owner_name": "Ananth Menon",
  "printer": "ananthmenon10",
  "printer_name": "Ananth Menon",
  "spec_source": "community",
  "health_check_path": "/me/",
  "auth": {
    "type": "api_key",
    "header": "sessionid",
    "format": "",
    "env_vars": [
      "FANTASY_PREMIER_LEAGUE_SESSION_COOKIE"
    ],
    "env_var_specs": [
      {
        "name": "FANTASY_PREMIER_LEAGUE_SESSION_COOKIE",
        "kind": "harvested",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ],
    "scheme": "sessionCookie",
    "in": "cookie",
    "verify_path": "/me/"
  },
  "config": {
    "format": "toml",
    "path": "~/.config/xfpl/config.toml"
  },
  "resources": {
    "bootstrap-static": {
      "description": "Manage bootstrap static",
      "endpoints": {
        "get": {
          "method": "GET",
          "path": "/bootstrap-static/",
          "description": "~1.5MB. The single most important read in the FPL API. Loaded once\nand cached locally for all entity lookups.",
          "params": [],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
    "dream-team": {
      "description": "Manage dream team",
      "endpoints": {
        "get": {
          "method": "GET",
          "path": "/dream-team/{eventId}/",
          "description": "Highest-scoring XI for a gameweek",
          "params": [
            {
              "name": "eventId",
              "type": "int",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "Event id",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
    "element-summary": {
      "description": "Manage element summary",
      "endpoints": {
        "get": {
          "method": "GET",
          "path": "/element-summary/{elementId}/",
          "description": "Per-player detail (history + upcoming fixtures)",
          "params": [
            {
              "name": "elementId",
              "type": "int",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "Element id",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
    "elite-json": {
      "description": "Manage elite json",
      "base_url": "https://livefpl.us",
      "endpoints": {
        "get-elite-aggregates": {
          "method": "GET",
          "path": "/elite.json",
          "description": "Aggregated picks, captaincy %, ownership, and chip usage among the\ntop 10,000 ranked managers. ~10KB, refreshed each gameweek.",
          "params": [],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
