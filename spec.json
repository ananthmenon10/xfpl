    "lh-api2": {
      "description": "Manage lh api2",
      "base_url": "https://livefpl.us",
      "endpoints": {
        "get-planner-snapshot": {
          "method": "GET",
          "path": "/LH_api2/planner/snapshot",
          "base_url": "https://livefpl-api-489391001748.europe-west4.run.app",
          "description": "Returns FT, bank, chips_available, base_gw, eleven, picks, benches,\nbought_values per element_id, manager_name, original picks (start of\nGW), epicks (effective picks after auto-subs). Used by LiveFPL's\ntransfer planner UI.",
          "params": [
            {
              "name": "id",
              "type": "int",
              "required": true,
              "positional": false,
              "default": null,
              "description": "Id",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
    "livefplapi": {
      "description": "Manage livefplapi",
      "base_url": "https://livefpl.us",
      "endpoints": {
        "get-live-team": {
          "method": "GET",
          "path": "/livefplapi/{teamId}",
          "base_url": "https://www.livefpl.net",
          "description": "THE primary LiveFPL transcendence endpoint. Returns:\n- GWrank: current gameweek rank\n- GWrank2: projected/secondary rank\n- a_e / a_o / a_t: average scores (entry/overall/top tiers)\n- arrow_*: visual rank-direction indicators\n- avg_similarity: how template the team is\n- bench, benchzz: bench points + bench element_ids\n- buds: similar-manager comparisons\n- cache: cache key\n- calcplayerptsd: live calculated points per element_id\n- and ~40 more fields\nSingle endpoint per team; ~80KB. Public, no auth.",
          "params": [
            {
              "name": "teamId",
              "type": "int",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "Team id",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "",
            "item": ""
          },
          "pagination": null,
          "no_auth": true
        }
      }
    },
    "locals-league-id-json": {
      "description": "Manage locals league id json",
      "base_url": "https://livefpl.us",
      "endpoints": {
        "get-league-locals-snapshot": {
          "method": "GET",
          "path": "/locals_{leagueId}.json",
          "description": "Available for indexed (popular) leagues; small leagues 404 here and\nmust use the dynamic livefplapi path on www.livefpl.net.",
          "params": [
            {
              "name": "leagueId",
              "type": "int",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
