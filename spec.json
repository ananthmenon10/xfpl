        "transfers": {
          "description": "Manage transfers",
          "endpoints": {
            "get-entry": {
              "method": "GET",
              "path": "/entry/{managerId}/transfers/",
              "description": "Manager transfers (all transfers this season)",
              "params": [
                {
                  "name": "managerId",
                  "type": "int",
                  "required": true,
                  "positional": true,
                  "path_param": true,
                  "default": null,
                  "description": "Manager id",
                  "fields": null
                }
              ],
              "body": [],
              "response": {
                "type": "",
                "item": ""
              },
              "pagination": null,
              "no_auth": true
            }
          }
        }
      }
    },
    "event": {
      "description": "Manage event",
      "endpoints": {},
      "sub_resources": {
        "live": {
          "description": "Manage live",
          "endpoints": {
            "get-event": {
              "method": "GET",
              "path": "/event/{eventId}/live/",
              "description": "Live gameweek stats (per-player points and explain breakdown)",
              "params": [
                {
                  "name": "eventId",
                  "type": "int",
                  "required": true,
                  "positional": true,
                  "path_param": true,
                  "default": null,
                  "description": "Event id",
                  "fields": null
                }
              ],
              "body": [],
              "response": {
                "type": "",
                "item": ""
