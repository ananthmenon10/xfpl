    "fixtures": {
      "description": "Manage fixtures",
      "endpoints": {
        "get": {
          "method": "GET",
          "path": "/fixtures/",
          "description": "All season fixtures (optionally filtered by event)",
          "params": [
            {
              "name": "event",
              "type": "int",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Event",
              "fields": null
